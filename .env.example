# ─────────────────────────────────────────────────────────────────────────────
# Kidroo — environment variables
#
# Copy this file to `.env` and fill in the real values. Every key listed here
# is consumed by the runtime; missing keys will fail loudly at startup.
#
# NEVER commit `.env`. Only `.env.example` is tracked.
# ─────────────────────────────────────────────────────────────────────────────

# ─── LLM providers ──────────────────────────────────────────────────────────

# Primary: Groq (LLaMA 3.1 70B Versatile). 14,400 req/day free.
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Fallback: Cerebras (LLaMA 3.1 70B). ~2,000 req/day free.
# Auto-failover kicks in on Groq 429. Get one at: https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-...

# ─── External tools ─────────────────────────────────────────────────────────

# Firecrawl — web scraping → clean markdown for research agent.
# 500 pages/mo free. Get one at: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# Exa — semantic search for niche/trend keywords.
# Generous free tier. Get one at: https://exa.ai
EXA_API_KEY=...

# Composio — YouTube OAuth bridge + YOUTUBE_UPLOAD_VIDEO action.
# Get one at: https://app.composio.dev/settings/api-keys
# YouTube OAuth is NOT stored here — use `composio connections create --toolkit YOUTUBE --user-id <channel_name>`.
COMPOSIO_API_KEY=...

# ─── Supabase ───────────────────────────────────────────────────────────────

# Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...                    # public — safe to expose to browser
SUPABASE_SERVICE_KEY=eyJhbGciOi...                 # SECRET — server only
SUPABASE_DB_URL=postgresql://postgres:...@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ─── Durable workflow orchestrator (Hatchet) ───────────────────────────────

# Hatchet Cloud free tier OR self-hosted on Koyeb.
# Dashboard: https://cloud.onhatchet.run (cloud) or your self-host URL.
HATCHET_CLIENT_TOKEN=...
HATCHET_CLIENT_HOST_PORT=engine.hatchet-tools.com:7077   # cloud default; change if self-hosting

# ─── Application config ────────────────────────────────────────────────────

# Global kill switch. Set to `false` to reject any new job. Default: true.
PIPELINE_ENABLED=true

# Max concurrent video pipelines per user. Default: 6.
MAX_CONCURRENT_VIDEOS_PER_USER=6

# Where downloaded videos are staged on disk. Default: /tmp/kidroo.
# On Koyeb this is ephemeral — files are auto-purged after upload.
DOWNLOAD_STAGING_DIR=/tmp/kidroo

# ─── Frontend (Next.js) ────────────────────────────────────────────────────

# Exposed to the browser — must be `NEXT_PUBLIC_` prefixed.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000     # local dev; prod = Koyeb URL
