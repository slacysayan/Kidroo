# ─────────────────────────────────────────────────────────────────────────────
# Kidroo — environment variables
#
# Copy this file to `.env` and fill in the real values. Every key listed here
# is consumed by the runtime; missing keys will fail loudly at startup
# (see agents/lib/config.py — pydantic-settings validation).
#
# NEVER commit `.env`. Only `.env.example` is tracked.
# ─────────────────────────────────────────────────────────────────────────────

# ─── LLM providers (always streamed) ───────────────────────────────────────
# stream_complete() tries Groq first, fails over to Cerebras on pre-stream OR
# mid-stream error. See docs/INTEGRATIONS.md#llm-providers.

# Primary: Groq. Free tier: 14,400 req/day.
# Get one: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Default production model. Override per-agent if needed.
# Options (free tier): llama-3.3-70b-versatile, openai/gpt-oss-120b, moonshotai/kimi-k2-instruct-0905
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback: Cerebras. Free tier ~2,000 req/day; sub-second TTFB.
# Get one: https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-...
CEREBRAS_MODEL=llama-3.3-70b

# ─── Research tools ─────────────────────────────────────────────────────────

# Tavily — primary web-search / URL lookup for the research agent.
# Two keys: TAVILY_API_KEY is primary, TAVILY_API_KEY_FALLBACK kicks in on 429/5xx.
# Get keys: https://app.tavily.com
TAVILY_API_KEY=tvly-dev-...
TAVILY_API_KEY_FALLBACK=tvly-dev-...

# Firecrawl — deep-scrape (markdown extraction of a single URL) when Tavily
# snippets aren't enough. 500 pages/mo free. https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# Exa — semantic similarity search for niche/trend discovery. https://exa.ai
EXA_API_KEY=...

# ─── Integrations ───────────────────────────────────────────────────────────

# Composio — YouTube OAuth bridge + YOUTUBE_UPLOAD_VIDEO action.
# https://app.composio.dev/settings/api-keys
# Per-channel OAuth is NOT stored here — run:
#   composio connections create --toolkit YOUTUBE --user-id <channel_alias>
COMPOSIO_API_KEY=ak_...

# ─── Supabase (full auth: email/password + magic link + OAuth) ─────────────

# Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# New Supabase key scheme (Nov 2024+). Some clients still use the JWT anon key.
# Set BOTH during the migration window; agents/lib/config.py prefers the
# publishable key when present.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only. Bypasses RLS — keep OUT of the frontend bundle.
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_SERVICE_KEY=eyJhbGciOi...   # legacy JWT service-role key

# Direct Postgres connection — used by migrations and JobLogger writes.
SUPABASE_DB_URL=postgresql://postgres:<password>@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ─── Durable workflow orchestrator (Hatchet) ────────────────────────────────

# Hatchet Cloud: https://cloud.onhatchet.run
# Self-host on Koyeb: see docs/ARCHITECTURE.md
HATCHET_CLIENT_TOKEN=eyJhbGci...
HATCHET_CLIENT_HOST_PORT=engine.hatchet-tools.com:7077   # cloud default

# ─── Application config ─────────────────────────────────────────────────────

# Global kill switch. Set `false` to reject any new job.
PIPELINE_ENABLED=true

# Max concurrent video pipelines per user.
MAX_CONCURRENT_VIDEOS_PER_USER=6

# Where downloaded videos are staged. Ephemeral on Koyeb.
DOWNLOAD_STAGING_DIR=/tmp/kidroo

# Structured-logging level. Options: debug | info | warning | error
LOG_LEVEL=info

# ─── Frontend (Next.js — must be NEXT_PUBLIC_ prefixed to reach browser) ───

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
